---
/**
 * Blog listing page. Posts loaded server-side via EmDash.
 */
import Base from "../../layouts/Base.astro";
import { getEmDashCollection } from "emdash";
import { EmDashImage } from "emdash/ui";

export const prerender = false;

const { entries: posts, cacheHint } = await getEmDashCollection("posts", {
  status: "published",
  limit: 20,
});
if (cacheHint) Astro.cache.set(cacheHint);
---

<Base title="Blog — Store" description="Stories, guides, and updates from our team.">
  <section class="py-12 sm:py-16">
    <div class="mx-auto max-w-6xl px-6">
      <div>
        <h1 class="text-3xl font-bold tracking-tight text-foreground">Journal</h1>
        <p class="mt-2 text-muted-foreground">Stories, guides, and updates.</p>
      </div>

      {posts.length === 0 ? (
        <div class="py-20 text-center">
          <h3 class="text-lg font-medium text-foreground">No posts yet</h3>
          <p class="mt-2 text-sm text-muted-foreground">Check back soon for new articles.</p>
        </div>
      ) : (
        <div class="mt-8 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <a href={`/posts/${post.data.slug}`} class="group">
              {post.data.featured_image ? (
                <div class="aspect-[16/9] overflow-hidden rounded-lg border border-border bg-secondary">
                  <EmDashImage
                    image={post.data.featured_image}
                    class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                  />
                </div>
              ) : (
                <div class="flex aspect-[16/9] items-center justify-center rounded-lg border border-border bg-secondary text-muted-foreground">
                  <svg class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                  </svg>
                </div>
              )}
              <div class="mt-4">
                <h2 class="text-lg font-semibold text-foreground transition-colors group-hover:text-muted-foreground">
                  {post.data.title}
                </h2>
                {post.data.excerpt && (
                  <p class="mt-2 line-clamp-2 text-sm text-muted-foreground">{post.data.excerpt}</p>
                )}
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</Base>
