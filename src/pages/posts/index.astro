---
import { getEmDashCollection } from "emdash";
import { Image } from "emdash/ui";
import Base from "../../layouts/Base.astro";

export const prerender = false;

let posts: any[] = [];
try {
  const result = await getEmDashCollection("posts", { orderBy: { published_at: "desc" } });
  posts = result.entries;
  Astro.cache.set(result.cacheHint);
} catch {}
---

<Base title="Blog" description="Latest articles and updates">
  <div class="max-w-4xl mx-auto px-6 py-10">
    <h1 class="text-3xl font-bold mb-8">Blog</h1>

    {posts.length === 0 ? (
      <p class="opacity-60">No posts yet. <a href="/_emdash/admin/content/posts/new" class="link link-primary">Create one</a>.</p>
    ) : (
      <div class="space-y-6">
        {posts.map((post) => (
          <a href={`/posts/${post.id}`} class="card card-side bg-base-200 hover:shadow-md transition-shadow">
            {post.data.featured_image && (
              <figure class="w-48 shrink-0"><Image image={post.data.featured_image} /></figure>
            )}
            <div class="card-body">
              <h2 class="card-title">{post.data.title}</h2>
              {post.data.excerpt && <p class="opacity-60 line-clamp-2">{post.data.excerpt}</p>}
              {post.data.publishedAt && (
                <p class="text-sm opacity-40">{post.data.publishedAt.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" })}</p>
              )}
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</Base>
