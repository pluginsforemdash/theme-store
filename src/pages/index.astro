---
import { getEmDashCollection } from "emdash";
import { Image } from "emdash/ui";
import Base from "../layouts/Base.astro";

export const prerender = false;

let posts: any[] = [];
try {
  const result = await getEmDashCollection("posts", { orderBy: { published_at: "desc" }, limit: 3 });
  posts = result.entries;
  Astro.cache.set(result.cacheHint);
} catch {}
---

<Base title="Store — Built with EmDash">
  <div class="hero min-h-[60vh] bg-base-200">
    <div class="hero-content text-center">
      <div class="max-w-2xl">
        <h1 class="text-5xl font-bold">Welcome to the Store</h1>
        <p class="py-6 text-lg opacity-70">Quality products, curated with care. Powered by EmDash CMS.</p>
        <a href="/shop" class="btn btn-primary btn-lg">Browse Products</a>
      </div>
    </div>
  </div>

  <section class="max-w-6xl mx-auto px-6 py-16">
    <h2 class="text-3xl font-bold mb-8">Featured Products</h2>
    <div id="featured-products" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="col-span-full text-center py-8"><span class="loading loading-spinner loading-lg"></span></div>
    </div>
  </section>

  {posts.length > 0 && (
    <section class="bg-base-200 py-16">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-3xl font-bold mb-8">From the Blog</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {posts.map((post) => (
            <a href={`/posts/${post.id}`} class="card bg-base-100 shadow-sm hover:shadow-md transition-shadow">
              {post.data.featured_image && (
                <figure><Image image={post.data.featured_image} /></figure>
              )}
              <div class="card-body">
                <h3 class="card-title text-base">{post.data.title}</h3>
                {post.data.excerpt && <p class="text-sm opacity-60 line-clamp-2">{post.data.excerpt}</p>}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="py-16 text-center">
    <h2 class="text-2xl font-bold mb-4">Ready to shop?</h2>
    <a href="/shop" class="btn btn-primary">View All Products</a>
  </section>

  <script is:inline>
    fetch("/_emdash/api/plugins/commerce/storefront/products", {
      method: "POST", headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ limit: 4 }),
    }).then(r => r.json()).then(res => {
      const products = (res.data ?? res).items ?? [];
      const grid = document.getElementById("featured-products");
      if (!grid) return;
      if (products.length === 0) { grid.innerHTML = '<p class="col-span-full text-center opacity-60">No products yet.</p>'; return; }
      grid.innerHTML = products.map(p => `
        <a href="/product/${p.slug}" class="card bg-base-100 shadow-sm hover:shadow-md transition-shadow">
          ${p.images?.[0] ? `<figure><img src="${p.images[0]}" alt="${p.name}" class="h-48 w-full object-cover" /></figure>` : `<figure class="bg-base-200 h-48 flex items-center justify-center"><span class="opacity-30">No image</span></figure>`}
          <div class="card-body p-4">
            <h3 class="card-title text-sm">${p.name}</h3>
            <div class="flex items-center gap-2">
              ${p.compareAtPrice ? `<span class="line-through opacity-40 text-sm">$${(p.compareAtPrice/100).toFixed(2)}</span>` : ""}
              <span class="font-bold">${p.priceRange ? `From $${(p.priceRange.min/100).toFixed(2)}` : `$${(p.price/100).toFixed(2)}`}</span>
              ${p.compareAtPrice ? '<div class="badge badge-secondary badge-sm">Sale</div>' : ""}
            </div>
          </div>
        </a>
      `).join("");
    }).catch(() => {
      const grid = document.getElementById("featured-products");
      if (grid) grid.innerHTML = '<p class="col-span-full text-center opacity-60">Failed to load.</p>';
    });
  </script>
</Base>
