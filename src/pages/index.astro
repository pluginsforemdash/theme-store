---
/**
 * Homepage: Hero, featured products, recent blog posts, and CTA.
 * Products are loaded client-side; blog posts are loaded server-side.
 */
import Base from "../layouts/Base.astro";
import { getEmDashCollection } from "emdash";
import { EmDashImage } from "emdash/ui";

export const prerender = false;

const { entries: posts, cacheHint } = await getEmDashCollection("posts", {
  limit: 3,
  status: "published",
});
if (cacheHint) Astro.cache.set(cacheHint);
---

<Base title="Store — Premium Products" description="Discover our curated collection of premium products. Quality meets design.">
  <!-- Hero -->
  <section class="relative overflow-hidden border-b border-border">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_rgba(255,255,255,0.05)_0%,_transparent_70%)]"></div>
    <div class="relative mx-auto max-w-6xl px-6 py-24 sm:py-32 lg:py-40">
      <div class="max-w-2xl">
        <h1 class="text-4xl font-bold tracking-tight text-foreground sm:text-5xl lg:text-6xl">
          Curated for the
          <span class="text-muted-foreground">discerning</span>
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-muted-foreground">
          Premium products selected for quality, design, and lasting value. Every item in our collection meets the highest standards.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href="/shop"
            class="inline-flex items-center justify-center rounded-md bg-primary px-6 py-3 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
          >
            Browse Collection
          </a>
          <a
            href="/posts"
            class="inline-flex items-center justify-center rounded-md border border-border bg-background px-6 py-3 text-sm font-medium text-foreground shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
          >
            Read Our Journal
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Products -->
  <section class="py-16 sm:py-24">
    <div class="mx-auto max-w-6xl px-6">
      <div class="flex items-end justify-between">
        <div>
          <h2 class="text-2xl font-bold tracking-tight text-foreground sm:text-3xl">Featured Products</h2>
          <p class="mt-2 text-muted-foreground">Our most popular items this season.</p>
        </div>
        <a href="/shop" class="hidden text-sm font-medium text-muted-foreground transition-colors hover:text-foreground sm:inline-flex">
          View all &rarr;
        </a>
      </div>

      <div id="featured-products" class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        <!-- Loading skeleton -->
        <div class="animate-pulse">
          <div class="aspect-square rounded-lg bg-secondary"></div>
          <div class="mt-3 h-4 w-3/4 rounded bg-secondary"></div>
          <div class="mt-2 h-4 w-1/4 rounded bg-secondary"></div>
        </div>
        <div class="animate-pulse">
          <div class="aspect-square rounded-lg bg-secondary"></div>
          <div class="mt-3 h-4 w-3/4 rounded bg-secondary"></div>
          <div class="mt-2 h-4 w-1/4 rounded bg-secondary"></div>
        </div>
        <div class="animate-pulse hidden sm:block">
          <div class="aspect-square rounded-lg bg-secondary"></div>
          <div class="mt-3 h-4 w-3/4 rounded bg-secondary"></div>
          <div class="mt-2 h-4 w-1/4 rounded bg-secondary"></div>
        </div>
        <div class="animate-pulse hidden lg:block">
          <div class="aspect-square rounded-lg bg-secondary"></div>
          <div class="mt-3 h-4 w-3/4 rounded bg-secondary"></div>
          <div class="mt-2 h-4 w-1/4 rounded bg-secondary"></div>
        </div>
      </div>

      <div class="mt-8 text-center sm:hidden">
        <a href="/shop" class="text-sm font-medium text-muted-foreground transition-colors hover:text-foreground">
          View all products &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- Recent Blog Posts -->
  {posts.length > 0 && (
    <section class="border-t border-border py-16 sm:py-24">
      <div class="mx-auto max-w-6xl px-6">
        <div class="flex items-end justify-between">
          <div>
            <h2 class="text-2xl font-bold tracking-tight text-foreground sm:text-3xl">From the Journal</h2>
            <p class="mt-2 text-muted-foreground">Stories, guides, and updates.</p>
          </div>
          <a href="/posts" class="hidden text-sm font-medium text-muted-foreground transition-colors hover:text-foreground sm:inline-flex">
            View all &rarr;
          </a>
        </div>

        <div class="mt-8 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <a href={`/posts/${post.data.slug}`} class="group">
              {post.data.featured_image && (
                <div class="aspect-[16/9] overflow-hidden rounded-lg border border-border bg-secondary">
                  <EmDashImage
                    image={post.data.featured_image}
                    class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                  />
                </div>
              )}
              <div class="mt-4">
                <h3 class="text-lg font-semibold text-foreground transition-colors group-hover:text-muted-foreground">
                  {post.data.title}
                </h3>
                {post.data.excerpt && (
                  <p class="mt-2 line-clamp-2 text-sm text-muted-foreground">{post.data.excerpt}</p>
                )}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="border-t border-border bg-card py-16 sm:py-24">
    <div class="mx-auto max-w-2xl px-6 text-center">
      <h2 class="text-2xl font-bold tracking-tight text-foreground sm:text-3xl">
        Start shopping today
      </h2>
      <p class="mt-4 text-muted-foreground">
        Free shipping on orders over $100. Easy returns within 30 days.
      </p>
      <a
        href="/shop"
        class="mt-8 inline-flex items-center justify-center rounded-md bg-primary px-8 py-3 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
      >
        Browse the Collection
      </a>
    </div>
  </section>
</Base>

<script is:inline>
  fetch("/_emdash/api/plugins/commerce/storefront/products", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ limit: 4 }),
  })
    .then(function (r) { return r.json(); })
    .then(function (res) {
      var result = res.data ?? res;
      var products = result.items ?? result.products ?? [];
      var container = document.getElementById("featured-products");
      if (!container || products.length === 0) return;

      container.innerHTML = products
        .map(function (p) {
          var imgSrc = "";
          if (p.images && p.images.length > 0) {
            var img = p.images[0];
            imgSrc = typeof img === "string" ? img : img.src || "/_emdash/api/media/file/" + img.id;
          }
          var priceStr = "$" + ((p.price || 0) / 100).toFixed(2);
          var compareStr = p.compareAtPrice
            ? '<span class="ml-2 text-muted-foreground line-through">$' + (p.compareAtPrice / 100).toFixed(2) + "</span>"
            : "";
          return (
            '<a href="/product/' + p.slug + '" class="group block">' +
            '<div class="aspect-square overflow-hidden rounded-lg border border-border bg-secondary">' +
            (imgSrc
              ? '<img src="' + imgSrc + '" alt="' + (p.name || "").replace(/"/g, "&quot;") + '" class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" loading="lazy" />'
              : '<div class="flex h-full items-center justify-center text-muted-foreground"><svg class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" /></svg></div>') +
            "</div>" +
            '<div class="mt-3">' +
            '<h3 class="text-sm font-medium text-foreground transition-colors group-hover:text-muted-foreground">' + (p.name || "Product") + "</h3>" +
            '<p class="mt-1 text-sm font-semibold text-foreground">' + priceStr + compareStr + "</p>" +
            "</div>" +
            "</a>"
          );
        })
        .join("");
    })
    .catch(function () {
      var container = document.getElementById("featured-products");
      if (container) container.innerHTML = '<p class="col-span-full text-sm text-muted-foreground">Unable to load products.</p>';
    });
</script>
