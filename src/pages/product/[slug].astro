---
import Base from "../../layouts/Base.astro";
export const prerender = false;
const { slug } = Astro.params;
---

<Base title="Product" description="">
  <div class="max-w-6xl mx-auto px-6 py-10">
    <div class="breadcrumbs text-sm mb-6">
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/shop">Shop</a></li>
        <li class="opacity-60" id="breadcrumb-name">Loading...</li>
      </ul>
    </div>

    <div id="product-loading" class="text-center py-20"><span class="loading loading-spinner loading-lg"></span></div>

    <div id="product-content" class="hidden">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10">
        <!-- Image -->
        <div>
          <div id="product-image" class="bg-base-200 rounded-box overflow-hidden aspect-square flex items-center justify-center">
            <span class="opacity-30">No image</span>
          </div>
        </div>

        <!-- Details -->
        <div>
          <h1 id="product-name" class="text-3xl font-bold mb-2"></h1>
          <div id="product-price" class="text-2xl font-bold mb-4"></div>
          <div id="product-stock" class="mb-4"></div>
          <p id="product-description" class="opacity-70 mb-6"></p>

          <!-- Variants -->
          <div id="product-variants" class="hidden mb-6">
            <label class="label"><span class="label-text font-semibold">Options</span></label>
            <select id="variant-select" class="select select-bordered w-full max-w-xs"></select>
          </div>

          <!-- Quantity -->
          <div class="mb-6">
            <label class="label"><span class="label-text font-semibold">Quantity</span></label>
            <div class="join">
              <button id="qty-minus" class="btn btn-sm join-item">-</button>
              <input id="qty-input" type="number" value="1" min="1" max="99" class="input input-sm input-bordered join-item w-16 text-center" />
              <button id="qty-plus" class="btn btn-sm join-item">+</button>
            </div>
          </div>

          <!-- Add to cart -->
          <button id="add-to-cart" class="btn btn-primary btn-lg w-full sm:w-auto">Add to Cart</button>
          <div id="add-feedback" class="mt-2 hidden"></div>
        </div>
      </div>

      <!-- Related -->
      <div id="related-section" class="hidden mt-16">
        <h2 class="text-2xl font-bold mb-6">You may also like</h2>
        <div id="related-grid" class="grid grid-cols-2 lg:grid-cols-4 gap-6"></div>
      </div>
    </div>

    <div id="product-error" class="hidden text-center py-20">
      <h2 class="text-2xl font-bold mb-2">Product not found</h2>
      <a href="/shop" class="btn btn-primary mt-4">Back to Shop</a>
    </div>
  </div>

  <script is:inline define:vars={{ slug }}>
    const api = (route, body) => fetch(`/_emdash/api/plugins/commerce/${route}`, {
      method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(body),
    }).then(r => r.json()).then(r => r.data ?? r);

    const SESSION_KEY = "store_cart_session";
    function getSessionId() {
      let id = localStorage.getItem(SESSION_KEY);
      if (!id) { id = crypto.randomUUID(); localStorage.setItem(SESSION_KEY, id); }
      return id;
    }

    let product = null;
    let selectedVariant = null;

    api("storefront/product", { slug }).then(p => {
      product = p;
      document.getElementById("product-loading").classList.add("hidden");
      document.getElementById("product-content").classList.remove("hidden");
      document.getElementById("breadcrumb-name").textContent = p.name;
      document.title = p.name + " — Store";
      document.getElementById("product-name").textContent = p.name;
      document.getElementById("product-description").textContent = p.description || p.shortDescription || "";

      // Price
      const priceEl = document.getElementById("product-price");
      if (p.compareAtPrice) {
        priceEl.innerHTML = `<span class="line-through opacity-40 text-lg mr-2">$${(p.compareAtPrice/100).toFixed(2)}</span> $${(p.price/100).toFixed(2)} <div class="badge badge-secondary ml-2">Sale</div>`;
      } else if (p.priceRange) {
        priceEl.textContent = `From $${(p.priceRange.min/100).toFixed(2)}`;
      } else {
        priceEl.textContent = `$${(p.price/100).toFixed(2)}`;
      }

      // Stock
      const stockEl = document.getElementById("product-stock");
      if (p.stockStatus === "out_of_stock") stockEl.innerHTML = '<div class="badge badge-error">Out of Stock</div>';
      else if (p.stockStatus === "low_stock") stockEl.innerHTML = '<div class="badge badge-warning">' + p.stockDisplay + '</div>';
      else if (p.stockStatus === "on_backorder") stockEl.innerHTML = '<div class="badge badge-info">Available on Backorder</div>';
      else stockEl.innerHTML = '<div class="badge badge-success">In Stock</div>';

      // Image
      if (p.images?.[0]) {
        document.getElementById("product-image").innerHTML = `<img src="${p.images[0]}" alt="${p.name}" class="w-full h-full object-cover" />`;
      }

      // Variants
      if (p.variants?.length > 0) {
        const container = document.getElementById("product-variants");
        const select = document.getElementById("variant-select");
        container.classList.remove("hidden");
        select.innerHTML = p.variants.map(v => `<option value="${v.id}">${v.name}${v.price !== undefined ? ` — $${(v.price/100).toFixed(2)}` : ""}</option>`).join("");
        selectedVariant = p.variants[0].id;
        select.addEventListener("change", () => { selectedVariant = select.value; });
      }

      // Disable add to cart if out of stock
      if (p.stockStatus === "out_of_stock" && !p.backordersAllowed) {
        document.getElementById("add-to-cart").disabled = true;
        document.getElementById("add-to-cart").textContent = "Out of Stock";
        document.getElementById("add-to-cart").classList.replace("btn-primary", "btn-disabled");
      }

      // Related products
      api("storefront/related", { productId: p.id, limit: 4 }).then(rel => {
        if (rel.items?.length > 0) {
          document.getElementById("related-section").classList.remove("hidden");
          document.getElementById("related-grid").innerHTML = rel.items.map(r => `
            <a href="/product/${r.slug}" class="card bg-base-100 shadow-sm hover:shadow-md transition-shadow">
              ${r.images?.[0] ? `<figure><img src="${r.images[0]}" alt="${r.name}" class="h-36 w-full object-cover" /></figure>` : ""}
              <div class="card-body p-3">
                <h3 class="text-sm font-medium">${r.name}</h3>
                <span class="font-bold text-sm">$${(r.price/100).toFixed(2)}</span>
              </div>
            </a>
          `).join("");
        }
      }).catch(() => {});

    }).catch(() => {
      document.getElementById("product-loading").classList.add("hidden");
      document.getElementById("product-error").classList.remove("hidden");
    });

    // Quantity
    document.getElementById("qty-minus")?.addEventListener("click", () => {
      const input = document.getElementById("qty-input");
      if (input.value > 1) input.value = Number(input.value) - 1;
    });
    document.getElementById("qty-plus")?.addEventListener("click", () => {
      const input = document.getElementById("qty-input");
      input.value = Number(input.value) + 1;
    });

    // Add to cart
    document.getElementById("add-to-cart")?.addEventListener("click", async () => {
      if (!product) return;
      const btn = document.getElementById("add-to-cart");
      const feedback = document.getElementById("add-feedback");
      btn.classList.add("loading");

      try {
        const qty = Number(document.getElementById("qty-input").value) || 1;
        const body = { sessionId: getSessionId(), productId: product.id, quantity: qty };
        if (selectedVariant) body.variantId = selectedVariant;
        const result = await api("storefront/cart/add", body);

        if (result.success) {
          feedback.innerHTML = '<div class="alert alert-success py-2 text-sm"><span>Added to cart!</span></div>';
          feedback.classList.remove("hidden");
          window.dispatchEvent(new Event("cart-updated"));
          setTimeout(() => feedback.classList.add("hidden"), 3000);
        } else {
          feedback.innerHTML = `<div class="alert alert-error py-2 text-sm"><span>${result.error || "Failed"}</span></div>`;
          feedback.classList.remove("hidden");
        }
      } catch {
        feedback.innerHTML = '<div class="alert alert-error py-2 text-sm"><span>Something went wrong</span></div>';
        feedback.classList.remove("hidden");
      }
      btn.classList.remove("loading");
    });
  </script>
</Base>
