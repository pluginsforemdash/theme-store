---
/**
 * Order confirmation page shown after successful Stripe checkout.
 */
import Base from "../../layouts/Base.astro";

export const prerender = false;
---

<Base title="Order Confirmed — Store" description="Your order has been placed successfully.">
  <section class="py-20 sm:py-28">
    <div class="mx-auto max-w-xl px-6 text-center">
      <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full border-2 border-foreground/20 bg-card">
        <svg class="h-8 w-8 text-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>

      <h1 class="mt-6 text-3xl font-bold tracking-tight text-foreground">Order Confirmed</h1>
      <p class="mt-4 text-lg text-muted-foreground">
        Thank you for your purchase. We've received your order and are getting it ready.
      </p>

      <div class="mt-8 rounded-lg border border-border bg-card p-6 text-left">
        <h2 class="font-semibold text-foreground">What happens next?</h2>
        <ol class="mt-4 space-y-3">
          <li class="flex gap-3 text-sm text-muted-foreground">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-secondary text-xs font-medium text-secondary-foreground">1</span>
            You'll receive an order confirmation email shortly.
          </li>
          <li class="flex gap-3 text-sm text-muted-foreground">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-secondary text-xs font-medium text-secondary-foreground">2</span>
            We'll prepare your order for shipping.
          </li>
          <li class="flex gap-3 text-sm text-muted-foreground">
            <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-secondary text-xs font-medium text-secondary-foreground">3</span>
            You'll get a shipping confirmation with tracking info.
          </li>
        </ol>
      </div>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:justify-center">
        <a
          href="/shop"
          class="inline-flex items-center justify-center rounded-md bg-primary px-6 py-2.5 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90"
        >
          Continue Shopping
        </a>
        <a
          href="/"
          class="inline-flex items-center justify-center rounded-md border border-border bg-background px-6 py-2.5 text-sm font-medium text-foreground shadow-sm transition-colors hover:bg-accent hover:text-accent-foreground"
        >
          Back to Home
        </a>
      </div>
    </div>
  </section>
</Base>
