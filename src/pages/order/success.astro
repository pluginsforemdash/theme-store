---
import Base from "../../layouts/Base.astro";
export const prerender = false;
---

<Base title="Order Confirmed" description="Your order was successful">
  <div class="max-w-2xl mx-auto px-6 py-20 text-center">
    <div class="flex justify-center mb-6">
      <div class="bg-success/20 text-success rounded-full p-4">
        <svg class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
      </div>
    </div>
    <h1 class="text-3xl font-bold mb-2">Order Confirmed!</h1>
    <p class="opacity-60 text-lg mb-8">Thank you for your purchase. You'll receive a confirmation email shortly.</p>

    <div class="flex justify-center gap-4">
      <a href="/shop" class="btn btn-primary">Continue Shopping</a>
      <a href="/" class="btn btn-ghost">Back to Home</a>
    </div>
  </div>
</Base>
