---
import Base from "../layouts/Base.astro";
export const prerender = false;
---

<Base title="Cart" description="Your shopping cart">
  <div class="max-w-4xl mx-auto px-6 py-10">
    <h1 class="text-3xl font-bold mb-8">Shopping Cart</h1>

    <div id="cart-loading" class="text-center py-12"><span class="loading loading-spinner loading-lg"></span></div>
    <div id="cart-empty" class="hidden text-center py-12">
      <p class="text-lg opacity-60 mb-4">Your cart is empty</p>
      <a href="/shop" class="btn btn-primary">Continue Shopping</a>
    </div>

    <div id="cart-content" class="hidden">
      <div class="overflow-x-auto">
        <table class="table">
          <thead>
            <tr>
              <th>Product</th>
              <th>Price</th>
              <th>Quantity</th>
              <th>Total</th>
              <th></th>
            </tr>
          </thead>
          <tbody id="cart-items"></tbody>
        </table>
      </div>

      <!-- Discount -->
      <div class="flex gap-2 mt-6 max-w-sm">
        <input id="discount-input" type="text" placeholder="Discount code" class="input input-bordered flex-1" />
        <button id="discount-btn" class="btn btn-outline">Apply</button>
      </div>
      <div id="discount-feedback" class="mt-2 hidden"></div>

      <!-- Summary -->
      <div class="card bg-base-200 mt-8 max-w-sm ml-auto">
        <div class="card-body">
          <div class="flex justify-between"><span class="opacity-60">Subtotal</span><span id="cart-subtotal" class="font-semibold">$0.00</span></div>
          <div id="cart-discount-row" class="hidden flex justify-between text-success"><span>Discount</span><span id="cart-discount">-$0.00</span></div>
          <div class="divider my-1"></div>
          <div class="flex justify-between text-lg font-bold"><span>Total</span><span id="cart-total">$0.00</span></div>
          <a href="/checkout" class="btn btn-primary mt-4">Proceed to Checkout</a>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    const SESSION_KEY = "store_cart_session";
    function getSessionId() {
      let id = localStorage.getItem(SESSION_KEY);
      if (!id) { id = crypto.randomUUID(); localStorage.setItem(SESSION_KEY, id); }
      return id;
    }
    const api = (route, body) => fetch(`/_emdash/api/plugins/commerce/${route}`, {
      method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(body),
    }).then(r => r.json()).then(r => r.data ?? r);

    function loadCart() {
      api("storefront/cart", { sessionId: getSessionId() }).then(cart => {
        document.getElementById("cart-loading").classList.add("hidden");
        const items = cart.items ?? [];

        if (items.length === 0) {
          document.getElementById("cart-empty").classList.remove("hidden");
          document.getElementById("cart-content").classList.add("hidden");
          return;
        }

        document.getElementById("cart-content").classList.remove("hidden");
        const tbody = document.getElementById("cart-items");
        tbody.innerHTML = items.map(item => `
          <tr>
            <td>
              <div class="flex items-center gap-3">
                ${item.image ? `<div class="avatar"><div class="w-12 rounded"><img src="${typeof item.image === "string" ? item.image : "/_emdash/api/media/file/" + item.image.id}" alt="" /></div></div>` : ""}
                <span class="font-medium">${item.name}</span>
              </div>
            </td>
            <td>$${((item.price||0)/100).toFixed(2)}</td>
            <td>
              <div class="join">
                <button class="btn btn-xs join-item qty-change" data-product="${item.productId}" data-variant="${item.variantId||""}" data-qty="${item.quantity - 1}">-</button>
                <span class="btn btn-xs join-item no-animation">${item.quantity}</span>
                <button class="btn btn-xs join-item qty-change" data-product="${item.productId}" data-variant="${item.variantId||""}" data-qty="${item.quantity + 1}">+</button>
              </div>
            </td>
            <td class="font-semibold">$${((item.price||0) * item.quantity / 100).toFixed(2)}</td>
            <td><button class="btn btn-ghost btn-xs qty-change" data-product="${item.productId}" data-variant="${item.variantId||""}" data-qty="0">Remove</button></td>
          </tr>
        `).join("");

        // Quantity change handlers
        tbody.querySelectorAll(".qty-change").forEach(btn => {
          btn.addEventListener("click", () => {
            const body = {
              sessionId: getSessionId(),
              productId: btn.dataset.product,
              quantity: Number(btn.dataset.qty),
            };
            if (btn.dataset.variant) body.variantId = btn.dataset.variant;
            api("storefront/cart/update", body).then(() => {
              window.dispatchEvent(new Event("cart-updated"));
              loadCart();
            });
          });
        });

        // Totals
        const subtotal = items.reduce((s, i) => s + (i.price||0) * i.quantity, 0);
        const discount = cart.discountAmount || 0;
        document.getElementById("cart-subtotal").textContent = "$" + (subtotal/100).toFixed(2);
        document.getElementById("cart-total").textContent = "$" + ((subtotal - discount)/100).toFixed(2);

        if (discount > 0) {
          document.getElementById("cart-discount-row").classList.remove("hidden");
          document.getElementById("cart-discount").textContent = "-$" + (discount/100).toFixed(2);
        }
      }).catch(() => {
        document.getElementById("cart-loading").classList.add("hidden");
        document.getElementById("cart-empty").classList.remove("hidden");
      });
    }

    loadCart();

    // Discount code
    document.getElementById("discount-btn")?.addEventListener("click", async () => {
      const code = document.getElementById("discount-input").value.trim();
      if (!code) return;
      const feedback = document.getElementById("discount-feedback");
      const result = await api("storefront/cart/discount", { sessionId: getSessionId(), code });
      if (result.success) {
        feedback.innerHTML = '<div class="alert alert-success py-2 text-sm"><span>Discount applied!</span></div>';
        feedback.classList.remove("hidden");
        loadCart();
      } else {
        feedback.innerHTML = `<div class="alert alert-error py-2 text-sm"><span>${result.error || "Invalid code"}</span></div>`;
        feedback.classList.remove("hidden");
      }
    });
  </script>
</Base>
