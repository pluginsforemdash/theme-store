---
import Base from "../../layouts/Base.astro";
export const prerender = false;
---

<Base title="Shop" description="Browse all products">
  <div class="max-w-6xl mx-auto px-6 py-10">
    <h1 class="text-3xl font-bold mb-2">Shop</h1>
    <p class="opacity-60 mb-8">Browse our collection</p>

    <!-- Category tabs -->
    <div id="category-tabs" class="tabs tabs-border mb-8">
      <a class="tab tab-active" data-cat="">All</a>
    </div>

    <!-- Product grid -->
    <div id="product-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      <div class="col-span-full text-center py-12"><span class="loading loading-spinner loading-lg"></span></div>
    </div>
  </div>

  <script is:inline>
    const api = (route, body) => fetch(`/_emdash/api/plugins/commerce/${route}`, {
      method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(body),
    }).then(r => r.json()).then(r => r.data ?? r);

    let currentCategory = "";

    function renderProducts(products) {
      const grid = document.getElementById("product-grid");
      if (!grid) return;
      if (products.length === 0) {
        grid.innerHTML = '<p class="col-span-full text-center py-12 opacity-60">No products found.</p>';
        return;
      }
      grid.innerHTML = products.map(p => `
        <a href="/product/${p.slug}" class="card bg-base-100 shadow-sm hover:shadow-md transition-all">
          ${p.images?.[0]
            ? `<figure><img src="${p.images[0]}" alt="${p.name}" class="h-52 w-full object-cover" loading="lazy" /></figure>`
            : `<figure class="bg-base-200 h-52 flex items-center justify-center"><span class="opacity-30 text-sm">No image</span></figure>`}
          <div class="card-body p-4">
            <h2 class="card-title text-sm">${p.name}</h2>
            ${p.shortDescription ? `<p class="text-xs opacity-60 line-clamp-2">${p.shortDescription}</p>` : ""}
            <div class="flex items-center gap-2 mt-1">
              ${p.compareAtPrice ? `<span class="line-through opacity-40 text-xs">$${(p.compareAtPrice/100).toFixed(2)}</span>` : ""}
              <span class="font-bold">${p.priceRange ? `From $${(p.priceRange.min/100).toFixed(2)}` : `$${(p.price/100).toFixed(2)}`}</span>
              ${p.compareAtPrice ? '<div class="badge badge-secondary badge-xs">Sale</div>' : ""}
            </div>
            ${p.stockStatus === "out_of_stock" ? '<div class="badge badge-error badge-sm mt-2">Out of Stock</div>' : ""}
            ${p.stockStatus === "low_stock" ? '<div class="badge badge-warning badge-sm mt-2">Low Stock</div>' : ""}
          </div>
        </a>
      `).join("");
    }

    function loadProducts(category) {
      currentCategory = category;
      const grid = document.getElementById("product-grid");
      if (grid) grid.innerHTML = '<div class="col-span-full text-center py-12"><span class="loading loading-spinner loading-lg"></span></div>';

      const body = { limit: 20 };
      if (category) body.category = category;
      api("storefront/products", body).then(data => renderProducts(data.items ?? [])).catch(() => {
        if (grid) grid.innerHTML = '<p class="col-span-full text-center opacity-60">Failed to load.</p>';
      });
    }

    // Load categories and set up tabs
    api("storefront/categories", {}).then(data => {
      const cats = data.items ?? [];
      const tabs = document.getElementById("category-tabs");
      if (!tabs || cats.length === 0) return;

      cats.forEach(c => {
        const tab = document.createElement("a");
        tab.className = "tab";
        tab.textContent = c.name;
        tab.setAttribute("data-cat", c.id);
        tabs.appendChild(tab);
      });

      tabs.querySelectorAll(".tab").forEach(tab => {
        tab.addEventListener("click", () => {
          tabs.querySelectorAll(".tab").forEach(t => t.classList.remove("tab-active"));
          tab.classList.add("tab-active");
          loadProducts(tab.getAttribute("data-cat"));
        });
      });
    });

    loadProducts("");
  </script>
</Base>
