---
/**
 * Product card component for grid layouts.
 *
 * Since products are fetched client-side, this is a template
 * rendered via client-side JavaScript. This .astro file serves
 * as the canonical reference design and is used nowhere directly.
 * The actual rendering happens in <script> blocks on shop/product pages.
 *
 * Product card HTML structure (used in JS template literals):
 *
 * <a href="/product/{slug}" class="group ...">
 *   <div class="aspect-square overflow-hidden rounded-lg bg-secondary">
 *     <img src="{image}" alt="{name}" class="..." />
 *   </div>
 *   <div class="mt-3">
 *     <h3 class="...">{name}</h3>
 *     <p class="...">${price}</p>
 *   </div>
 * </a>
 */
---

<!-- This component is a design reference. Product cards are rendered client-side. -->
<div class="product-card-reference hidden">
  <a href="#" class="group block">
    <div class="aspect-square overflow-hidden rounded-lg border border-border bg-secondary">
      <div class="flex h-full items-center justify-center text-muted-foreground">
        <svg class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </div>
    </div>
    <div class="mt-3">
      <h3 class="text-sm font-medium text-foreground group-hover:text-foreground/80 transition-colors">Product Name</h3>
      <p class="mt-1 text-sm font-semibold text-foreground">$0.00</p>
    </div>
  </a>
</div>
