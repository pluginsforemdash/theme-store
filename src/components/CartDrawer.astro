---
---

<div class="drawer drawer-end z-50" id="cart-drawer-root">
  <input id="cart-drawer-toggle" type="checkbox" class="drawer-toggle" />
  <div class="drawer-side">
    <label for="cart-drawer-toggle" aria-label="close sidebar" class="drawer-overlay"></label>
    <div class="bg-base-100 min-h-full w-80 p-4 flex flex-col">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold">Shopping Cart</h2>
        <label for="cart-drawer-toggle" class="btn btn-sm btn-ghost btn-circle">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </label>
      </div>

      <div id="cart-drawer-items" class="flex-1 overflow-y-auto">
        <p class="text-sm opacity-60">Your cart is empty.</p>
      </div>

      <div id="cart-drawer-footer" class="hidden border-t border-base-300 pt-4 mt-4 space-y-2">
        <div class="flex justify-between font-semibold">
          <span>Subtotal</span>
          <span id="cart-drawer-subtotal">$0.00</span>
        </div>
        <a href="/cart" class="btn btn-outline btn-block btn-sm">View Cart</a>
        <a href="/checkout" class="btn btn-primary btn-block btn-sm">Checkout</a>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  window.openCartDrawer = function() {
    const toggle = document.getElementById("cart-drawer-toggle");
    if (toggle) toggle.checked = true;
    loadDrawerCart();
  };

  function loadDrawerCart() {
    const sessionId = localStorage.getItem("store_cart_session");
    const container = document.getElementById("cart-drawer-items");
    const footer = document.getElementById("cart-drawer-footer");
    if (!sessionId || !container) return;

    fetch("/_emdash/api/plugins/commerce/storefront/cart", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ sessionId }),
    })
      .then(r => r.json())
      .then(res => {
        const cart = res.data ?? res;
        const items = cart.items ?? [];

        if (items.length === 0) {
          container.innerHTML = '<p class="text-sm opacity-60">Your cart is empty.</p>';
          if (footer) footer.classList.add("hidden");
          return;
        }

        container.innerHTML = items.map(item => `
          <div class="flex gap-3 py-2 border-b border-base-200">
            <div class="avatar">
              <div class="w-12 rounded">
                ${item.image
                  ? '<img src="' + (typeof item.image === "string" ? item.image : "/_emdash/api/media/file/" + item.image.id) + '" alt="" />'
                  : '<div class="bg-base-200 w-full h-full flex items-center justify-center text-xs opacity-40">No img</div>'}
              </div>
            </div>
            <div class="flex-1">
              <p class="text-sm font-medium">${item.name}</p>
              <p class="text-xs opacity-60">${item.quantity} x $${((item.price || 0) / 100).toFixed(2)}</p>
            </div>
          </div>
        `).join("");

        const subtotal = items.reduce((s, i) => s + (i.price || 0) * (i.quantity || 1), 0);
        document.getElementById("cart-drawer-subtotal").textContent = "$" + (subtotal / 100).toFixed(2);
        if (footer) footer.classList.remove("hidden");
      })
      .catch(() => {});
  }
</script>
