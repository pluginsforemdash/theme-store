---
const themes = [
  "light", "dark", "lofi", "black", "luxury", "dracula", "night", "coffee", "dim", "nord", "sunset",
  "cupcake", "bumblebee", "emerald", "corporate", "synthwave", "retro", "cyberpunk",
  "valentine", "halloween", "garden", "forest", "aqua", "pastel", "fantasy",
  "wireframe", "cmyk", "autumn", "business", "acid", "lemonade", "winter",
];
---

<div class="fixed bottom-4 right-4 z-50">
  <div class="dropdown dropdown-top dropdown-end">
    <div tabindex="0" role="button" class="btn btn-circle btn-sm shadow-lg">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"></path></svg>
    </div>
    <div tabindex="0" class="dropdown-content bg-base-200 rounded-box w-56 max-h-80 overflow-y-auto shadow-2xl p-2 mb-2">
      <div class="text-xs font-bold uppercase tracking-wider opacity-60 px-2 py-1 mb-1">Theme</div>
      {themes.map((theme) => (
        <button
          data-set-theme={theme}
          class="btn btn-sm btn-ghost justify-start w-full font-normal capitalize"
        >
          <div class="flex gap-1">
            <div data-theme={theme} class="rounded-sm w-2 h-4 bg-primary"></div>
            <div data-theme={theme} class="rounded-sm w-2 h-4 bg-secondary"></div>
            <div data-theme={theme} class="rounded-sm w-2 h-4 bg-accent"></div>
          </div>
          {theme}
        </button>
      ))}
    </div>
  </div>
</div>

<script is:inline>
  document.querySelectorAll("[data-set-theme]").forEach(btn => {
    btn.addEventListener("click", () => {
      const theme = btn.getAttribute("data-set-theme");
      document.documentElement.setAttribute("data-theme", theme);
      localStorage.setItem("store_theme", theme);
    });
  });
</script>
